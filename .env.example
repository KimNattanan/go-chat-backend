# App
APP_ENV=development
APP_NAME=go-chat-backend
APP_VERSION=1.0.0
# HTTP settings
HTTP_PORT=8000
# Logger
LOG_LEVEL=debug
# DB
DB_HOST=localhost
DB_PORT=5432
DB_USER=db_user
DB_PASSWORD=db_password
DB_NAME=db_name
# gRPC
GRPC_PORT=8081
# RMQ
RMQ_RPC_SERVER=rpc_server
RMQ_RPC_CLIENT=rpc_client
RMQ_URL=amqp://guest:guest@localhost:5672/
# Swagger
SWAGGER_ENABLED=true
#JWT
ACCESS_TTL=3600
REFRESH_TTL=604800